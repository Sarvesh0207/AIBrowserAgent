# Copy to .env and fill real values.
# NEVER commit .env or include it in zip/share — teammates should create their own .env.

# Model keys (optional depending on your run mode)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Firecrawl key (required for Firecrawl-based agents)
FIRECRAWL_API_KEY=fc-your-key-here

# Model config (used by other agents in this repo)
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4.1-mini

# Browser / output config
HEADLESS=true
LOG_LEVEL=INFO
SCREENSHOT_DIR=outputs/screenshots
REPORT_DIR=outputs/reports
